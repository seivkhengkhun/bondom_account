# Copy to .env and adjust for your environment.
# NOTE: this is the committed TEMPLATE — real tokens belong in .env only!

# --- Database -------------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/digital_store
ECHO_SQL=false

# --- FastAPI server ---------------------------------------------------------
API_HOST=127.0.0.1
API_PORT=8000

# --- Telegram bot (from @BotFather) -----------------------------------------
BOT_TOKEN=123456789:replace-with-your-botfather-token

# --- Payments: Bakong KHQR ---------------------------------------------------
# Keep true while developing: QR + verification are simulated end-to-end.
PAYMENT_DEV_MODE=true
# Get a token at https://api-bakong.nbc.gov.kh/register (renew ~90 days).
BAKONG_TOKEN=replace-with-your-bakong-jwt
# Your Bakong account id, e.g. yourname@bank
BAKONG_ACCOUNT_ID=yourname@bank
MERCHANT_NAME=Bondom Account
MERCHANT_CITY=Battambang

# --- Reflex admin panel ------------------------------------------------------
# Required to sign in to the admin dashboard; leave empty to disable logins.
ADMIN_PASSWORD=
# When the panel is served from a remote host, browsers must reach the
# Reflex backend on the public address, e.g. http://your-server-ip:8001
# REFLEX_API_URL=http://your-server-ip:8001
